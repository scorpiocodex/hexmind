# ── HexMind runtime data ──────────────────────────────────────────────────────
# Database files (personal scan history — never commit)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Config with secrets or local paths
.hexmind/
~/.hexmind/

# Generated reports (output artifacts — not source)
hexmind-reports/
reports/
*.pdf
# Keep report templates
!hexmind/reports/templates/

# Temporary scanner output files
/tmp/hexmind_*
/tmp/hexmind_nmap_*
/tmp/hexmind_nikto_*
/tmp/hexmind_whatweb_*
/tmp/hexmind_gobuster_*

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
hexmind.log
hexmind_debug.log

# ── Security — never commit these ─────────────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa
id_ed25519
*.secret
secrets.toml
secrets.yaml
secrets.json
api_keys.txt

# ── Wordlists — large files, install separately ───────────────────────────────
# Comment this out if you want to commit the bundled common.txt
# hexmind/data/wordlists/
# Keep the small bundled wordlist, ignore large external ones
hexmind/data/wordlists/rockyou*.txt
hexmind/data/wordlists/directory-list-*.txt
hexmind/data/wordlists/dirbuster/
hexmind/data/wordlists/seclists/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

